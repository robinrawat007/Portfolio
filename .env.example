# --- Runtime mode ---
# Set to "true" if you deploy as a static export (e.g., GitHub Pages).
# Netlify: keep "false" so /api/chat runs server-side; Atlas uses n8n from the browser only in static mode and hits CORS.
NEXT_PUBLIC_STATIC_EXPORT="false"

# --- Atlas (Groq) ---
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"

# --- n8n Webhooks (for forms) ---
# Point these to your n8n webhook URLs so forms work on static hosting too.
NEXT_PUBLIC_ENQUIRY_WEBHOOK_URL=""
NEXT_PUBLIC_SERVICE_WEBHOOK_URL=""

# --- Email (used by /api/enquiry and /api/start-project) ---
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""

# Optional: override email From header (defaults to SMTP_USER)
EMAIL_FROM=""

# --- Google Sheets logging (service account) ---
# Create a Google Cloud service account, enable Google Sheets API,
# share your sheet with the service account email, then set these:
GOOGLE_SHEETS_SPREADSHEET_ID=""
GOOGLE_SHEETS_ENQUIRY_SHEET_NAME="Enquiry"
GOOGLE_SHEETS_SERVICE_SHEET_NAME="Service"
GOOGLE_SERVICE_ACCOUNT_EMAIL=""
# Paste the *entire* private key. If your platform requires single-line env vars,
# replace newlines with \n.
GOOGLE_PRIVATE_KEY=""
