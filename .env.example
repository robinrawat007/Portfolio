# --- Runtime mode ---
# Set to "true" only if deploying as a static export (no API routes).
# Netlify with SSR: keep "false".
NEXT_PUBLIC_STATIC_EXPORT="false"

# --- Atlas (Anthropic) ---
ANTHROPIC_API_KEY=""
# "claude-haiku-4-5-20251001" ← fast & cheap | "claude-sonnet-4-6" ← higher quality
ANTHROPIC_MODEL="claude-haiku-4-5-20251001"

# --- n8n Webhooks (contact + service forms) ---
# Override the hardcoded fallback URLs if you switch n8n workspaces.
NEXT_PUBLIC_ENQUIRY_WEBHOOK_URL=""
NEXT_PUBLIC_SERVICE_WEBHOOK_URL=""

# --- Analytics (pick one, both optional) ---
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""
NEXT_PUBLIC_GA_MEASUREMENT_ID=""

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# --- AI Embeddings ---
VOYAGE_API_KEY=""

# --- Knowledge Base Sync ---
# Any strong random string. Set the same value in your Supabase webhook header.
SYNC_KB_SECRET=""
